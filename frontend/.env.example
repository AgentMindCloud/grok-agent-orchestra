# Public origin of the FastAPI backend. In dev with the two services
# running on different ports, set this to the FastAPI port.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional override for the WebSocket origin. Defaults to the API URL
# with the protocol swapped to ws[s]://.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Public site name shown in the header.
NEXT_PUBLIC_SITE_NAME=Agent Orchestra
